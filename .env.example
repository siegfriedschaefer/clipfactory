# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=clipfabric
POSTGRES_PASSWORD=clipfabric
POSTGRES_DB=clipfabric
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://clipfabric:clipfabric@postgres:5432/clipfabric

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_ROOT=/storage

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# ── Workers ───────────────────────────────────────────────────────────────────
CPU_WORKER_CONCURRENCY=2
GPU_WORKER_CONCURRENCY=1

# ── WhisperX (Day 5-6) ────────────────────────────────────────────────────────
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
